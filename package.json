{
  "name": "code-and-safety",
  "version": "0.0.0",
  "private": true,
  "description": "Conversão de um arquivo HTML estático (`grade_react_ts_abril2026.html`) em uma aplicação React + TypeScript funcional. O arquivo original é uma grade de estudos com design visual próprio — tema escuro, tipografia Syne + DM Mono, paleta com acentos em amarelo-limão, azul e verde.",
  "homepage": "https://github.com/Tulio-Aguiar/Exercise-Change-to-React#readme",
  "bugs": {
    "url": "https://github.com/Tulio-Aguiar/Exercise-Change-to-React/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tulio-Aguiar/Exercise-Change-to-React.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "eslint.config.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "vite --open",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "24.12.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitejs/plugin-react-swc": "4.2.3",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "^16.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.3.2",
    "prettier": "3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
